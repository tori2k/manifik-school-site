---
---
<section class="hero" id="home">
  <div class="container-x hero__grid">
    <div class="hero__text">
      <div class="hero__tag">
        <span class="dot"></span>
        Школа вокала · Орехово-Зуево
      </div>

      <h1 class="hero__title">
        <span class="line">Тебе не нужно</span>
        <span class="line">уметь <em class="serif">петь</em>,</span>
        <span class="line">чтобы начать.</span>
      </h1>

      <p class="hero__desc">
        Мы поможем услышать и раскрыть свой голос —
        спокойно, без давления и сравнения.
        У нас поют те, кто тоже когда-то сомневался.
      </p>

      <div class="hero__actions">
        <a href="https://n1543290.yclients.com" target="_blank" rel="noopener" class="btn btn--solid">
          Записаться на занятие
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#path" class="btn btn--ghost">Как это работает</a>
      </div>
    </div>

    <!-- ─── VISUAL ─── -->
    <div class="hero__visual reveal-right">
      <div class="hero__frame">
        <img
          class="hero__image"
          src="/img/hero-bg.webp"
          alt="Занятие в школе вокала Manifik"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />

        <div class="hero__overlay">
          <div class="hero__badge">
            <span class="rec-dot"></span>
            Живое занятие
          </div>
        </div>
      </div>

      <!-- Sticker -->
      <div class="hero__sticker">
        <div class="sticker__inner">
          <span class="serif">«Голос —</span>
          <span class="serif" style="font-style: italic;">это ты»</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    padding-top: 130px;
    padding-bottom: 50px;
    display: flex;
    align-items: center;
    position: relative;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  /* Tag */
  .hero__tag {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 600; letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 30px;
  }
  .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.75); }
  }

  /* Title */
  .hero__title {
    font-size: clamp(46px, 6.2vw, 96px);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin-bottom: 30px;
    font-family: 'Manrope', sans-serif;
  }
  .hero__title .line { display: block; }
  .hero__title em {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
    padding: 0 4px;
  }

  .hero__desc {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 450px;
    margin-bottom: 38px;
  }

  /* ─── BUTTONS ─── */
  .hero__actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 28px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    transition: background 0.3s, color 0.3s, border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .btn--solid {
    background: var(--accent);
    color: var(--bg);
    box-shadow: 0 10px 30px color-mix(in oklab, var(--accent) 30%, transparent);
  }
  .btn--solid:hover {
    background: var(--accent-3);
    box-shadow: 0 16px 50px color-mix(in oklab, var(--accent) 55%, transparent);
  }
  .btn--ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-2);
  }
  .btn--ghost:hover { border-color: var(--text); }

  /* ─── VISUAL ─── */
  .hero__visual {
    position: relative;
    aspect-ratio: 4/5;
    width: 100%;
    max-width: 460px;
    margin-left: auto;
  }
  .hero__frame {
    position: relative;
    width: 100%; height: 100%;
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid var(--border-2);
    background: var(--bg-soft);
    box-shadow: 0 40px 100px color-mix(in oklab, var(--accent) 15%, transparent);
  }
  .hero__image {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: transform 0.6s cubic-bezier(.25,.46,.45,.94);
  }
  .hero__frame:hover .hero__image { transform: scale(1.03); }

  .hero__overlay {
    position: absolute;
    top: 20px; left: 20px;
    z-index: 2;
    pointer-events: none;
  }
  .hero__badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-size: 11px; font-weight: 600;
    color: var(--text);
    letter-spacing: 0.5px;
    border: 1px solid var(--border-2);
  }
  .rec-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #d64545;
    animation: rec 1.6s ease-in-out infinite;
  }
  @keyframes rec {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(0.75); }
  }

  /* Sticker */
  .hero__sticker {
    position: absolute;
    bottom: -28px; right: -28px;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 20px 50px color-mix(in oklab, var(--accent) 35%, transparent);
    animation: spin 22s linear infinite;
    z-index: 3;
  }
  .sticker__inner {
    font-size: 16px;
    line-height: 1.2;
    display: flex; flex-direction: column; gap: 2px;
    animation: spinBack 22s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes spinBack { to { transform: rotate(-360deg); } }

  /* Mobile */
  @media (max-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero__title { font-size: clamp(40px, 10vw, 64px); }
    .hero__visual { max-width: 320px; margin: 0 auto; }
    .hero__sticker { width: 120px; height: 120px; bottom: -20px; right: -10px; }
    .sticker__inner { font-size: 13px; }
    .btn--solid { font-size: 13px; padding: 14px 22px; }
    .hero__actions { flex-direction: column; align-items: stretch; }
    .btn { justify-content: center; }
  }
</style>

