---
---
<div class="ambience" aria-hidden="true">
  <div class="orb orb--1"></div>
  <div class="orb orb--2"></div>
</div>
<div id="progress-bar" aria-hidden="true"></div>

<style>
  .ambience {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
  }
  .orb--1 {
    width: 520px; height: 520px;
    top: -120px; right: -100px;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent) 22%, transparent) 0%, transparent 60%);
    animation: float1 22s ease-in-out infinite alternate;
  }
  .orb--2 {
    width: 420px; height: 420px;
    bottom: 6%; left: -140px;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent-2) 28%, transparent) 0%, transparent 60%);
    animation: float2 18s ease-in-out infinite alternate;
  }
  @keyframes float1 {
    0%   { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-100px, 120px) scale(1.15); }
  }
  @keyframes float2 {
    0%   { transform: translate(0, 0) scale(1); }
    100% { transform: translate(80px, -120px) scale(1.2); }
  }

  #progress-bar {
    position: fixed;
    top: 0; left: 0;
    height: 2px;
    z-index: 1000;
    background: var(--accent);
    width: 0%;
    box-shadow: 0 0 10px color-mix(in oklab, var(--accent) 60%, transparent);
  }
</style>

<script>
  const bar = document.getElementById('progress-bar');
  if (bar) {
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY / (document.body.scrollHeight - window.innerHeight);
      bar.style.width = (scrolled * 100) + '%';
    }, { passive: true });
  }
</script>
