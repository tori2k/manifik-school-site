---
interface Props { size?: number }
const { size = 54 } = Astro.props;
---
<a href="#home" class="logo">
  <img src="/img/logo-bird-transparent.png" alt="Manifik" width={size} height={size} class="logo__mark" />
  <span class="logo__word">
    <span class="logo__sub">Школа вокала</span>
    <span class="logo__name serif brand">Manifik</span>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    transition: transform 0.4s;
  }
  .logo:hover { transform: translateY(-1px); }
  .logo__mark {
    object-fit: contain;
    transition: transform 0.4s cubic-bezier(.25,.46,.45,.94);
  }
  .logo:hover .logo__mark { transform: rotate(-6deg) scale(1.05); }
  .logo__word {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .logo__sub {
    font-family: 'Manrope', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .logo__name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  [data-theme="cream"] .logo__sub  { color: #8a6756; }

  @media (max-width: 600px) {
    .logo__mark { width: 48px; height: 48px; }
    .logo__name { font-size: 20px; }
    .logo__sub { font-size: 9px; letter-spacing: 2px; }
  }
</style>
