---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const SITE_URL = 'https://manifik-school.ru';

const {
  title = 'Школа вокала «Манифик» — вокал, фортепиано, теория музыки',
  description = 'Тебе не нужно уметь петь, чтобы начать. Школа вокала в Орехово-Зуево для детей и взрослых. Вокал, фортепиано, теория музыки, английский, арт-терапия.',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImage = new URL('/og-image.jpg', SITE_URL).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicSchool',
  name: 'Школа вокала «Манифик»',
  alternateName: 'Manifik',
  description,
  url: SITE_URL,
  logo: new URL('/favicon.png', SITE_URL).toString(),
  image: ogImage,
  telephone: ['+7 915 408-40-12', '+7 995 508-40-12'],
  priceRange: '₽₽',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'ул. Ленина, 99',
    addressLocality: 'Орехово-Зуево',
    addressRegion: 'Московская область',
    addressCountry: 'RU',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 55.803,
    longitude: 38.975,
  },
  sameAs: [
    'https://t.me/manifik_vocal',
    'https://vk.ru/manifik_school',
    'https://www.instagram.com/manifik_school',
  ],
};
---
<!DOCTYPE html>
<html lang="ru" data-theme="cream">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#f6f0e7" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:site_name" content="Школа вокала «Манифик»" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Школа вокала Манифик" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&display=swap"
    rel="stylesheet"
  />

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <title>{title}</title>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <script is:inline>
    (function () {
      const saved = localStorage.getItem('manifik-theme');
      if (saved === 'sunset' || saved === 'cream') {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
